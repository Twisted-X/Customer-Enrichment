# Copy this file to .env and fill in real values.
# The server loads .env automatically via python-dotenv.

# ── Enrichment API auth ──────────────────────────────────────────────────────
# Required to call POST /api/enrich.  Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Set the same value in your NetSuite/Celigo HTTP connector header: X-API-Key
ENRICH_API_KEY=

# ── Google Places / Address Validation ──────────────────────────────────────
# Required for enrichment.  The same key is used for:
#   - Places Text Search API (batch pipeline)
#   - Address Validation API  (POST /api/enrich primary path)
#   - Places Details API (New) (POST /api/enrich primary path)
# Ensure all three APIs are enabled in Google Cloud Console for this key.
GOOGLE_PLACES_API_KEY=

# ── SerpApi (Layer 3 — Google Search without browser) ────────────────────────
# Required for Layer 3 detection.  Without this key Layer 3 is silently skipped
# and every check falls through to Playwright (Layer 4).
# Sign up at https://serpapi.com — free tier: 100 searches/month.
SERPAPI_KEY=

# ── SFTP ─────────────────────────────────────────────────────────────────────
# Required only when USE_SFTP=true (automated Celigo pipeline mode).
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_KEY_PATH=
SFTP_PASSWORD=
SFTP_INBOUND_DIR=
SFTP_REVIEW_DIR=
SFTP_ARCHIVE_DIR=

# ── Pipeline mode ─────────────────────────────────────────────────────────────
# Set to true for the automated Celigo flow (SFTP in/out).
# Set to false (or omit) for local manual runs using INPUT_FILE/OUTPUT_FILE.
USE_SFTP=false
INPUT_FILE=
OUTPUT_FILE=

# ── 2Captcha (Cloudflare Turnstile solver) ──────────────────────────────────
# Required only for sites with interactive Turnstile challenges (Boot Barn,
# Cavender's, etc.).  Leave blank to rely on patchright's auto-solve only.
# Sign up at https://2captcha.com — ~$3 per 1,000 Turnstile solves.
TWO_CAPTCHA_API_KEY=

# ── Dev HTTP cache (optional) ────────────────────────────────────────────────
# Enables disk caching for checker/_http_client.http_get during local dev.
# Use 1/true/yes to enable.
SCRAPER_DEV_CACHE=0
SCRAPER_DEV_CACHE_DIR=.dev_cache

# ── Proxy rotation (optional) ────────────────────────────────────────────────
# Comma-separated list of proxy URLs used in round-robin order for both
# curl_cffi HTTP requests and Playwright browser contexts.
# PROXY_LIST=http://user:pass@proxy1.example.com:8080,http://user:pass@proxy2.example.com:8080
PROXY_LIST=

# ── SKU database (optional overrides) ───────────────────────────────────────
# SKU_XLSX_FILENAME=twisted_x_skus_v107.xlsx
# SKU_CSV_FILENAME=twisted_x_sku.csv
# MIN_EXPECTED_STYLE_CODES=1000
